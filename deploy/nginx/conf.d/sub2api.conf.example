# =============================================================================
# Nginx Virtual Host Template for Sub2API (SSL + HTTP/2 + Streaming)
# =============================================================================
# Usage:
#   1. Copy this file: cp sub2api.conf.example yourdomain.com.conf
#   2. Replace YOUR_DOMAIN with your actual domain
#   3. Ensure SSL certificates exist at the configured paths
#   4. Test: nginx -t && nginx -s reload
# =============================================================================

map $http_upgrade $connection_upgrade {
    default upgrade;
    '' '';
}

server {
    listen 80;
    listen [::]:80;
    # >>> Replace with your domain <<<
    server_name YOUR_DOMAIN;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    # >>> Replace with your domain <<<
    server_name YOUR_DOMAIN;

    # >>> Update certificate paths <<<
    ssl_certificate /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;

    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;

    client_max_body_size 256m;

    # Health check endpoint (internal, no buffering)
    location = /health {
        proxy_pass http://sub2api:8080/health;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;

        proxy_buffering off;
        proxy_cache off;
    }

    # Main proxy — optimized for streaming/SSE (OpenAI stream:true)
    location / {
        proxy_pass http://sub2api:8080;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;

        # WebSocket support
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Streaming / SSE — disable all buffering
        proxy_buffering off;
        proxy_cache off;
        proxy_request_buffering off;
        gzip off;

        # Long-lived connections (streaming can last minutes/hours)
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        send_timeout 86400s;

        chunked_transfer_encoding on;

        add_header X-Accel-Buffering no always;
    }
}
